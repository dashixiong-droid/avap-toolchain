#!/usr/bin/env python
import os
import sys

# ── 最小化 FFmpeg 静态库（自编译，仅 VP9 + H.264 + swscale）────────
ffmpeg_build = "/tmp/ffmpeg-8.1.1"
ffmpeg_include_path = "/tmp/ffmpeg-minimal/include"

ffmpeg_static_libs = [
    os.path.join(ffmpeg_build, "libavformat", "libavformat.a"),
    os.path.join(ffmpeg_build, "libavcodec", "libavcodec.a"),
    os.path.join(ffmpeg_build, "libswscale", "libswscale.a"),
    os.path.join(ffmpeg_build, "libswresample", "libswresample.a"),
    os.path.join(ffmpeg_build, "libavutil", "libavutil.a"),
    "/opt/homebrew/Cellar/libvpx/1.16.0/lib/libvpx.a",
]

ffmpeg_sys_libs = ["z", "bz2", "iconv", "m"]
ffmpeg_frameworks = [
    "VideoToolbox", "CoreFoundation", "CoreMedia",
    "CoreVideo", "CoreServices", "Cocoa",
]

# ── Godot CPP ────────────────────────────────────────────────
godot_cpp_path = "godot-cpp"
env = SConscript(godot_cpp_path + "/SConstruct")

# 强制 arm64 only
env["ARCH"] = "arm64"

# C++17
env.Append(CXXFLAGS=["-std=c++17"])

# 静态链接 FFmpeg
for lib_path in ffmpeg_static_libs:
    if os.path.exists(lib_path):
        env.Append(LINKFLAGS=[lib_path])
    else:
        print("WARNING: FFmpeg static lib not found: " + lib_path)

env.Append(LIBS=ffmpeg_sys_libs)

for fw in ffmpeg_frameworks:
    env.Append(LINKFLAGS=["-framework", fw])

env.Append(LINKFLAGS=["-pthread"])

# 源文件 — 为 AVAP 源码单独加 FFmpeg include（不影响 godot-cpp）
# 用 Clone 创建子环境
avap_env = env.Clone()
avap_env.Append(CXXFLAGS=["-isystem", ffmpeg_include_path])

sources = avap_env.Glob("src/*.cpp")

if env["target"] == "editor":
    library = avap_env.SharedLibrary(
        "addons/avap/lib/libavap.{}.{}".format(env["platform"], "editor"),
        source=sources,
    )
elif env["target"] == "template_debug":
    library = avap_env.SharedLibrary(
        "addons/avap/lib/libavap.{}.{}".format(env["platform"], "template_debug"),
        source=sources,
    )
else:
    library = avap_env.SharedLibrary(
        "addons/avap/lib/libavap.{}.{}".format(env["platform"], "template_release"),
        source=sources,
    )

Default(library)