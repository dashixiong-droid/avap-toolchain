#!/usr/bin/env python
import os
import subprocess
import sys

# FFmpeg 路径（通过 pkg-config 获取）
ffmpeg_cflags = subprocess.check_output(["pkg-config", "--cflags", "libavcodec", "libavformat", "libavutil", "libswscale"], text=True).strip().split()
ffmpeg_libs = subprocess.check_output(["pkg-config", "--libs", "libavcodec", "libavformat", "libavutil", "libswscale"], text=True).strip().split()

# 将 -I 转换为 include 路径列表
ffmpeg_include = []
ffmpeg_lib_dirs = []
ffmpeg_lib_names = []

for flag in ffmpeg_cflags:
    if flag.startswith("-I"):
        ffmpeg_include.append(flag[2:])

for flag in ffmpeg_libs:
    if flag.startswith("-L"):
        ffmpeg_lib_dirs.append(flag[2:])
    elif flag.startswith("-l"):
        ffmpeg_lib_names.append(flag[2:])
    elif flag.endswith(".dylib") or flag.endswith(".so"):
        # 绝对路径的库文件
        ffmpeg_lib_dirs.append(os.path.dirname(flag))
        lib_name = os.path.basename(flag)
        # 去掉 lib 前缀和 .dylib 后缀
        if lib_name.startswith("lib"):
            lib_name = lib_name[3:]
        if ".dylib" in lib_name:
            lib_name = lib_name[:lib_name.index(".dylib")]
        elif ".so" in lib_name:
            lib_name = lib_name[:lib_name.index(".so")]
        if lib_name not in ffmpeg_lib_names:
            ffmpeg_lib_names.append(lib_name)

# Godot CPP 路径
godot_cpp_path = "godot-cpp"

env = SConscript(godot_cpp_path + "/SConstruct")

# 追加 FFmpeg 编译参数
env.Append(CPPPATH=ffmpeg_include)
env.Append(LIBPATH=ffmpeg_lib_dirs)
env.Append(LIBS=ffmpeg_lib_names)

# C++17
env.Append(CXXFLAGS=["-std=c++17"])

# 源文件
sources = ["src/avap_decoder.cpp", "src/register_types.cpp"]

# 构建动态库
if env["target"] == "editor":
    library = env.SharedLibrary(
        "addons/avap/lib/libavap.{}.{}".format(env["platform"], "editor"),
        source=sources,
    )
elif env["target"] == "template_debug":
    library = env.SharedLibrary(
        "addons/avap/lib/libavap.{}.{}".format(env["platform"], "template_debug"),
        source=sources,
    )
else:
    library = env.SharedLibrary(
        "addons/avap/lib/libavap.{}.{}".format(env["platform"], "template_release"),
        source=sources,
    )

Default(library)
